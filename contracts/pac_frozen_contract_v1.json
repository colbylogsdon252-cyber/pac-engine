{
  "required_fields": [
    "action",
    "target"
  ],
  "field_types": {
    "action": "bool",
    "target": "dict"
  },
  "nested_contracts": {
    "target": {
      "required_fields": [
        "id",
        "type"
      ],
      "field_types": {
        "id": "str",
        "type": "str"
      }
    }
  },
  "temporal": {
    "enabled": true,
    "timestamp_field": "proof_timestamp",
    "required_fields": [
      "proof_timestamp"
    ],
    "max_age_seconds": 300
  },
  "state_transitions": {
    "enabled": true,
    "current_state_field": "current_state",
    "requested_state_field": "requested_state",
    "entry_state": "__start__",
    "terminal_state": "__terminal__",
    "allowed": {
      "__start__": [
        "draft"
      ],
      "draft": [
        "validated"
      ],
      "validated": [
        "approved",
        "rejected"
      ],
      "approved": [
        "__terminal__"
      ],
      "rejected": [
        "__terminal__"
      ],
      "__terminal__": []
    }
  }
}
